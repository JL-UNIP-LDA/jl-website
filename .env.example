# ============================================================
# JL Unipessoal - Environment Variables
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Fill in ALL values below
# 3. NEVER share this file or commit it to Git
# ============================================================

# --- SERVER ---
# Port the Node.js app will listen on (Hostinger Node.js Manager sets this)
PORT=3000

# Set to "production" on Hostinger
NODE_ENV=production

# --- DATABASE (Neon.tech PostgreSQL) ---
# Get this from: https://console.neon.tech -> your project -> Connection Details
# It looks like: postgresql://user:password@ep-xxx.eu-west-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- OPENAI (AI FAQ Agent) ---
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SESSION SECURITY ---
# Any long random string (e.g.: type 40 random characters)
SESSION_SECRET=change-this-to-a-long-random-secret-string-here

# --- ADMIN PANEL ---
# Password to access /admin on the website
ADMIN_PASSWORD=jladmin2024
